{
  "id": "memoryos",
  "name": "MemoryOS",
  "version": "0.1.0",
  "entry": "dist/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {"type": "string", "default": "http://127.0.0.1:8765"},
      "userId": {"type": "string", "default": "local-user"},
      "projectId": {"type": "string"},
      "timeoutMs": {"type": "integer", "default": 2500}
    },
    "required": ["baseUrl"]
  }
}
